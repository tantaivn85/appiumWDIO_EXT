{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "webdriverio", "@wdio/globals/types", "@wdio/mocha-framework"],
    "outDir": "dist"
  },
  "ts-node": {
    "esm": true
  },
  "include": ["src", "tests", "wdio.conf.ts"]
}
